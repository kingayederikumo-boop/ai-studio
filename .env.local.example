# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Nvidia
NVIDIA_API_KEY_1=nvapi-...
NVIDIA_API_KEY_2=nvapi-...
NVIDIA_MODELS=nvidia/nemotron-3-ultra-550b-a55b,nvidia/nemotron-3-nano-omni-30b-a3b-reasoning,qwen/qwen2.5-coder-32b-instruct,deepseek-ai/deepseek-v4-pro,moonshotai/kimi-k2.b
NVIDIA_INFERENCE_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# LangChain API Keys for model rotation
LANGCHAIN_NVIDIA_API_KEY=...
LANGCHAIN_OPENAI_API_KEY=sk-...
LANGCHAIN_QWEN_API_KEY=...
LANGCHAIN_DEEPSEEK_API_KEY=...
LANGCHAIN_KIMI_API_KEY=...

# API Keys for authentication
NEXT_PUBLIC_API_KEY=your-api-key-1
API_KEY_2=your-api-key-2
API_KEY_3=your-api-key-3

# CORS
NEXT_PUBLIC_API_URL=http://localhost:3000
