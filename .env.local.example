# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Nvidia
NVIDIA_API_KEY_1=nvapi-...
NVIDIA_API_KEY_2=nvapi-...
NVIDIA_MODELS=meta/llama-2-70b-chat,meta/llama-2-13b-chat
NVIDIA_INFERENCE_MODEL=meta/llama-2-70b-chat

# API Keys for authentication
NEXT_PUBLIC_API_KEY=your-api-key-1
API_KEY_2=your-api-key-2
API_KEY_3=your-api-key-3

# CORS
NEXT_PUBLIC_API_URL=http://localhost:3000
